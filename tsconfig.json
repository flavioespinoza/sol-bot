{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"sourceMap": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
